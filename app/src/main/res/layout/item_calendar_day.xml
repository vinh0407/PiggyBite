<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="60dp"
    android:background="?attr/selectableItemBackground"
    android:padding="2dp">

    <View
        android:id="@+id/viewSelection"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/circle_bg_selection"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/tvDay"
        app:layout_constraintEnd_toEndOf="@id/tvDay"
        app:layout_constraintStart_toStartOf="@id/tvDay"
        app:layout_constraintTop_toTopOf="@id/tvDay" />

    <TextView
        android:id="@+id/tvDay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="19"
        android:textColor="@color/text_main"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tvDailyAmount"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/tvDailyAmount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textColor="@color/text_hint"
        android:textSize="9sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDay" />

</androidx.constraintlayout.widget.ConstraintLayout>