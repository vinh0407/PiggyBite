<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:icon="@drawable/icon_app_money"
        android:label="@string/app_name"
        android:roundIcon="@drawable/icon_app_money"
        android:supportsRtl="true"
        android:theme="@style/Theme.Money">

        <activity
            android:name=".ui.StatisticsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.ProfileActivity"
            android:exported="false" />


        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AddTransactionActivity"
            android:exported="false" />

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.RegisterActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AIChatActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AddFundActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AllFundsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.AllTransactionsActivity"
            android:exported="false" />

        <activity
            android:name=".ui.MapActivity"
            android:exported="false" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Money">
        </activity>

    </application>
</manifest>