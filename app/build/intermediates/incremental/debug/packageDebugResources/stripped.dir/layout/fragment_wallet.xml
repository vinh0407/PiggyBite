<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="120dp">

        <!-- Blue Header Background -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_curved"
            android:paddingBottom="40dp">

            <!-- Profile & Header Buttons -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/profileArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="80dp"
                android:paddingBottom="24dp"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <FrameLayout
                    android:id="@+id/flProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@drawable/ic_piggy_bank"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="@color/white"
                        app:strokeWidth="2dp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/circle_white"
                        android:padding="3dp"
                        android:src="@drawable/ic_settings"
                        app:tint="@color/primary_blue" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/flProfile"
                    app:layout_constraintStart_toEndOf="@id/flProfile"
                    app:layout_constraintTop_toTopOf="@id/flProfile">

                    <TextView
                        android:id="@+id/tvUserName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_placeholder"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSlogan"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_slogan"
                        android:textColor="#B3FFFFFF"
                        android:textSize="11sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvTotalBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/wallet_zero_balance"
                            android:textColor="#E0E0E0"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/ivToggleBalance"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="8dp"
                            android:src="@drawable/ic_eye"
                            android:padding="2dp"
                            app:tint="#E0E0E0"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="@string/total_balance" />
                    </LinearLayout>
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnMap"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/circle_bg_dark"
                    android:backgroundTint="#40FFFFFF"
                    android:padding="8dp"
                    android:src="@drawable/ic_home"
                    app:layout_constraintBottom_toBottomOf="@id/flProfile"
                    app:layout_constraintEnd_toStartOf="@id/btnSettings"
                    app:layout_constraintTop_toTopOf="@id/flProfile"
                    app:tint="@color/white" />

                <ImageButton
                    android:id="@+id/btnSettings"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_bg_dark"
                    android:backgroundTint="#40FFFFFF"
                    android:padding="10dp"
                    android:src="@drawable/ic_settings"
                    app:layout_constraintBottom_toBottomOf="@id/flProfile"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/flProfile"
                    app:tint="@color/white" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Donut Analysis Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-24dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:id="@+id/btnPrevAnalysis"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_down"
                        android:rotation="90"
                        app:tint="@color/text_hint"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />

                    <TextView
                        android:id="@+id/tvChartTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/wallet_analysis_month"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:gravity="center" />

                    <ImageView
                        android:id="@+id/btnNextAnalysis"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_arrow_down"
                        android:rotation="-90"
                        app:tint="@color/text_hint"
                        android:padding="4dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless" />
                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioGroup
                        android:id="@+id/rgChartToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_centerHorizontal="true"
                        android:background="@drawable/bg_pill_grey"
                        android:orientation="horizontal"
                        android:padding="2dp">
                        <RadioButton
                            android:id="@+id/rbExpense"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_pill_white"
                            android:button="@null"
                            android:checked="true"
                            android:paddingHorizontal="12dp"
                            android:text="@string/expense"
                            android:textColor="@color/primary_blue"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <RadioButton
                            android:id="@+id/rbIncome"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:button="@null"
                            android:paddingHorizontal="12dp"
                            android:text="@string/income"
                            android:textColor="@color/text_hint"
                            android:textSize="12sp" />
                    </RadioGroup>
                </RelativeLayout>

                <com.money.app.ui.PieChartView
                    android:id="@+id/pieChart"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="20dp" />

                <GridLayout
                    android:id="@+id/chartLegend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:columnCount="2" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Weekly Flow Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wallet_weekly_flow"
                        android:textColor="@color/text_main"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/btnViewFlowMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:text="@string/wallet_view_more"
                        android:textColor="@color/primary_blue"
                        android:textSize="12sp" />
                </RelativeLayout>

                <com.money.app.ui.LineChartView
                    android:id="@+id/lineChart"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:layout_marginTop="20dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:layout_gravity="center"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@color/expense_red" android:layout_gravity="center_vertical" android:contentDescription="@string/expense" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/expense" android:textSize="11sp" android:layout_marginEnd="16dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@color/income_green" android:layout_gravity="center_vertical" android:contentDescription="@string/income" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/income" android:textSize="11sp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Quick Actions Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <include layout="@layout/item_quick_action" android:id="@+id/actionAdd" />
            <include layout="@layout/item_quick_action" android:id="@+id/actionReport" />
            <include layout="@layout/item_quick_action" android:id="@+id/actionAIChat" />
            <include layout="@layout/item_quick_action" android:id="@+id/actionGoals" />

        </LinearLayout>

        <!-- Recent Transactions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_recent_trans"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/btnViewAllTrans"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/wallet_view_all"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/recentList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>

        <!-- Fund Management Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:paddingHorizontal="24dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/wallet_manage_funds"
                    android:textColor="@color/text_main"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/btnAddFund"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="@string/wallet_add_fund"
                    android:textColor="@color/primary_blue"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/fundsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>