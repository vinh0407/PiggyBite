<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_app">

    <!-- Header Area -->
    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:background="@drawable/bg_header_curved"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvLabelHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="@string/history_title"
        android:textColor="#B0C4FF"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvCurrentMonth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tháng 6, 2025"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@id/tvLabelHistory"
        app:layout_constraintTop_toBottomOf="@id/tvLabelHistory" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnExport"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_pill_grey"
        android:backgroundTint="#40FFFFFF"
        android:paddingHorizontal="16dp"
        android:text="@string/history_export_csv"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="@id/tvCurrentMonth"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvLabelHistory" />

    <!-- Summary Row -->
    <LinearLayout
        android:id="@+id/summaryRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvCurrentMonth">

        <include layout="@layout/item_cal_summary" android:id="@+id/summaryInc" />
        <include layout="@layout/item_cal_summary" android:id="@+id/summaryExp" />
        <include layout="@layout/item_cal_summary" android:id="@+id/summaryBal" />

    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cvCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/summaryRow">

        <CalendarView
            android:id="@+id/calendarView"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:theme="@style/Theme.Money"
            android:padding="8dp" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/dailyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/cvCalendar">
        <TextView
            android:id="@+id/tvSelectedDateLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ngày 19/06/2025"
            android:textColor="@color/text_main"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/tvDailyCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1 giao dịch"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvDailyList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dailyHeader" />

</androidx.constraintlayout.widget.ConstraintLayout>