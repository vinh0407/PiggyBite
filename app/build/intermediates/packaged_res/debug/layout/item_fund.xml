<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp"
    app:cardBackgroundColor="@color/dark_grey"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <TextView
            android:id="@+id/tvFundName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quỹ tiết kiệm"
            android:textColor="@color/text_hint"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvFundAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0đ"
            android:textColor="@color/accent"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnGop"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_pill_dark"
                android:paddingHorizontal="16dp"
                android:text="Góp"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <Space android:layout_width="8dp" android:layout_height="wrap_content"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnRut"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_pill_dark"
                android:paddingHorizontal="16dp"
                android:text="Rút"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="12sp" />

            <Space android:layout_width="8dp" android:layout_height="wrap_content"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnXoa"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_pill_dark"
                android:paddingHorizontal="16dp"
                android:text="Xóa"
                android:textAllCaps="false"
                android:textColor="@color/expense_red"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>